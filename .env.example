APP_NAME=news-pipeline-demo
APP_HOST=0.0.0.0
APP_PORT=8080
MOCK=true

NEWS_BASE_URL=http://8.135.4.46:8000
NEWS_BOARD=sub
NEWS_LIMIT=3

# DashScope mode: fill these if you want Qwen text + image generation.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TEXT_MODEL=qwen-plus
DASHSCOPE_IMAGE_MODEL=wan2.7-image

# Shared OpenAI-compatible mode: use one base_url/key for both text and image.
USE_SHARED_MODEL=true
SHARED_MODEL_BASE_URL=
SHARED_MODEL_API_KEY=
SHARED_MODEL_NAME=
SHARED_IMAGE_MODEL_NAME=

# Split model mode: use independent text/image services.
TEXT_MODEL_BASE_URL=
TEXT_MODEL_API_KEY=
TEXT_MODEL_NAME=

# Stage model routing (optional). If empty, fallback to SHARED_MODEL_NAME / TEXT_MODEL_NAME.
MODEL_RESEARCH_NAME=
MODEL_FACTCHECK_NAME=
MODEL_WRITER_NAME=
MODEL_IMAGE_PROMPT_NAME=
MODEL_WECHAT_ARTICLE_NAME=

IMAGE_MODEL_BASE_URL=
IMAGE_MODEL_API_KEY=
IMAGE_MODEL_NAME=

# Bocha web fact-check search.
BOCHA_API_KEY=
FACTCHECK_ENABLE_WEB_SEARCH=true
FACTCHECK_SEARCH_PROVIDER=bocha
FACTCHECK_MAX_QUERIES_PER_CLAIM=5
FACTCHECK_MAX_RESULTS_PER_QUERY=5
FACTCHECK_SEARCH_LANG_MODE=auto
FACTCHECK_NEWS_ONLY=true

DOUYIN_OPEN_BASE_URL=https://open.douyin.com
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=
